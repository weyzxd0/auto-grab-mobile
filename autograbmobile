-- LOGIC
local IsActive = false

local function toggle()
    IsActive = not IsActive
    
    if IsActive then
        StatusLabel.Text = "INSTANT E: ACTIVE"
        StatusLabel.TextColor3 = Color3.fromRGB(0,255,170)
        TweenService:Create(strokeMain, TweenInfo.new(0.4), {Color = Color3.fromRGB(0,255,170)}):Play()
    else
        StatusLabel.Text = "INSTANT E: OFF [Q]"
        StatusLabel.TextColor3 = Color3.fromRGB(255,70,70)
        TweenService:Create(strokeMain, TweenInfo.new(0.4), {Color = Color3.fromRGB(170,0,255)}):Play()
    end
end

